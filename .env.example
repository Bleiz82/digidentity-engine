# ============================================
# DigIdentity Engine — Environment Variables
# ============================================
# COPIA questo file come .env nella root del progetto
# e inserisci i valori reali. MAI committare il file .env

# ---- App ----
APP_BASE_URL=https://digidentityagency.it
REPORTS_DIR=./reports
SECRET_KEY=genera_una_chiave_casuale_lunga_qui_con_openssl_rand_hex_32
DEBUG=false

# ---- Supabase ----
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGci...chiave_anon
SUPABASE_SERVICE_KEY=eyJhbGci...chiave_service_role

# ---- AI: Anthropic Claude (primario) ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4000

# ---- AI: OpenAI (backup) ----
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# ---- AI: Perplexity (ricerche contestuali) ----
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro

# ---- Google APIs ----
GOOGLE_PAGESPEED_API_KEY=AIza...

# ---- SerpAPI ----
SERP_API_KEY=...
SERP_API_MONTHLY_LIMIT=250

# ---- Apify ----
APIFY_API_KEY=apify_api_... # Token da Apify Console
ENABLE_GOOGLE_MAPS_APIFY=false # true = usa Apify per Google Maps (costa ~$0.10, più dati); false = usa solo SerpAPI

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_live_... # oppure sk_test_... per testing
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PREMIUM=price_... # Opzionale

# ---- Email: Gmail SMTP ----
GMAIL_SMTP_USER=digidentityagency@gmail.com
GMAIL_SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx # App password da Google Account
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# ---- Email: Resend (alternativo) ----
RESEND_API_KEY=re_... # Opzionale

# ---- Email: Sender Info ----
SENDER_EMAIL=digidentityagency@gmail.com
SENDER_NAME=DigIdentity Agency

# ---- WhatsApp: Meta Business API ----
WHATSAPP_ACCESS_TOKEN=EAAxxxx... # Token permanente
WHATSAPP_PHONE_NUMBER_ID=123456789 # Phone Number ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=token_casuale_per_webhook # Opzionale

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ---- Rate Limiting ----
RATE_LIMIT_PER_IP=5

# SERPER.DEV - sostituto SerpAPI (2.500 crediti gratis, no CC)
# Registrati su: https://serper.dev
SERPER_KEY=

# GOOGLE CUSTOM SEARCH (opzionale, fallback)
# Chiave: https://console.cloud.google.com
# CX: https://programmablesearchengine.google.com
GOOGLE_CSE_KEY=
GOOGLE_CX=

# RAPIDAPI - sostituto Apify per social (100 req/mese gratis)
# Registrati su: https://rapidapi.com/andryerics/api/facebook-tiktok-instagram-scraper
RAPIDAPI_KEY=